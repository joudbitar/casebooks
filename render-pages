#!/usr/bin/env bash
# render-pages - render casebook PDF pages to PNG images and open them.
# Usage:
#   ./render-pages Columbia_2021 137 146      # render pages 137-146
#   ./render-pages Wharton_2025 40            # single page 40
# Output: ~/casebooks/.exhibits/<name>-p<page>.png  (opened in Preview)

BOOKS="$HOME/casebooks/casebooks"
OUT="$HOME/casebooks/.exhibits"
NAME="$1"; FIRST="$2"; LAST="${3:-$2}"

if [ -z "$NAME" ] || [ -z "$FIRST" ]; then
  echo "usage: render-pages <casebook_name> <first_page> [last_page]" >&2
  echo "  e.g. render-pages Columbia_2021 144 146" >&2
  echo "  (names: $(ls "$BOOKS" | tr '\n' ' '))" >&2
  exit 1
fi

PDF="$BOOKS/$NAME/$NAME.pdf"
[ -f "$PDF" ] || { echo "no PDF at $PDF" >&2; exit 1; }
mkdir -p "$OUT"

files=()
for p in $(seq "$FIRST" "$LAST"); do
  base="$OUT/${NAME}-p${p}"
  pdftoppm -f "$p" -l "$p" -r 200 -png "$PDF" "$base" 2>/dev/null
  # pdftoppm appends the page number; normalize to a clean name
  produced="$(ls "${base}"*.png 2>/dev/null | head -1)"
  [ -n "$produced" ] && mv -f "$produced" "${base}.png" && files+=("${base}.png")
done

echo "rendered ${#files[@]} page(s) to $OUT"
[ ${#files[@]} -gt 0 ] && open "${files[@]}"
